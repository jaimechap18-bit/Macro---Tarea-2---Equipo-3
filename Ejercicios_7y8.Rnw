der_exceso_mex <- exceso_mex_tabla |>
  slice((mitad_exceso_mex + 1):n())

if (nrow(der_exceso_mex) < nrow(izq_exceso_mex)) {
  der_exceso_mex <- bind_rows(
    der_exceso_mex,
    tibble(anio = NA_integer_, exceso_retorno = NA_real_)
  )
}

exceso_mex_tabla_4 <- bind_cols(
  izq_exceso_mex,
  der_exceso_mex |> rename(Año_2 = anio, Exceso_2 = exceso_retorno)
