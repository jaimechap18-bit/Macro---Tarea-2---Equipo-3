Para España, la tasa de crecimiento real del consumo agregado se obtuvo a partir de la serie anual de gasto en consumo final de los hogares y de las ISFLSH a precios constantes. El cálculo se realizó como la variación porcentual del nivel de consumo real respecto al año inmediato anterior. Esta variable permite resumir la evolución anual del consumo agregado real de la economía española.

<<covarianzas_consumo_agregado, echo=FALSE, message=FALSE, warning=FALSE>>=
base_cov_mex <- exceso_mex |>
  inner_join(crecimiento_consumo_mex, by = "anio")

base_cov_usa <- exceso_usa |>
  inner_join(crecimiento_consumo_usa, by = "anio")

base_cov_esp <- exceso_esp |>
  inner_join(crecimiento_consumo_esp, by = "anio")

cov_mex <- cov(
  base_cov_mex$exceso_retorno,
  base_cov_mex$crecimiento_consumo_real,
  use = "complete.obs"
)

cov_usa <- cov(
  base_cov_usa$exceso_retorno,
  base_cov_usa$crecimiento_consumo_real,
  use = "complete.obs"
)

cov_esp <- cov(
  base_cov_esp$exceso_retorno,
  base_cov_esp$crecimiento_consumo_real,
  use = "complete.obs"
)

tabla_cov_consumo_agregado <- tibble(
  Pais = c("México", "Estados Unidos", "España"),
  Covarianza = round(c(cov_mex, cov_usa, cov_esp), 6)
)
@

\begin{center}
Tabla. Covarianza entre el exceso de retorno y la tasa de crecimiento real del consumo agregado
\end{center}
<<tabla_covarianzas_consumo_agregado, echo=FALSE, results='asis'>>=
cat("\\begin{center}\n")
print(
  kable(
    tabla_cov_consumo_agregado,
    format = "latex",
    booktabs = TRUE,
    col.names = c("País", "Covarianza"),
    digits = 6,
    align = "lc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia.}\n")
cat("\\end{center}\n")
@

Para cada economía, la covarianza se obtuvo a partir de la serie anual del exceso de retorno del mercado accionario y de la tasa de crecimiento real del consumo agregado. Primero se empalmaron ambas variables por año, de modo que cada observación correspondiera al mismo periodo calendario. Posteriormente, se calculó la covarianza muestral entre ambas series, es decir, una medida de asociación lineal basada en todas las observaciones anuales disponibles en la muestra y no un promedio simple de diferencias.

En términos económicos, una covarianza positiva indica que los años en que el exceso de retorno es más alto tienden a coincidir con años de mayor crecimiento real del consumo; en cambio, una covarianza negativa sugiere que ambas variables tienden a moverse en sentido opuesto. Esta estadística resume el grado en que el premio por invertir en acciones y la dinámica del consumo agregado se mueven conjuntamente a lo largo del tiempo.

\newpage
\textbf{(f) Covarianza entre el exceso de retorno y el crecimiento real del consumo de bienes durables y servicios}

<<durables_servicios_mex, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_durables_servicios_mex <- "CP_indice monthly - INEGI.xlsx"

durables_servicios_mex_raw <- read_excel(
  ruta_durables_servicios_mex,
  sheet = "Tabulado",
  col_names = FALSE
)

anios_fila <- unlist(durables_servicios_mex_raw[5, ])
periodos_fila <- unlist(durables_servicios_mex_raw[6, ])

anios_rellenados <- c()
anio_actual <- NA

for (i in seq_along(anios_fila)) {
  if (!is.na(anios_fila[i]) && anios_fila[i] != "") {
    anio_actual <- as.character(anios_fila[i])
  }
  anios_rellenados[i] <- anio_actual
}

cols_anuales <- which(periodos_fila == "Anual")

anios_anuales <- as.integer(anios_rellenados[cols_anuales])

valores_durables_mex <- unlist(durables_servicios_mex_raw[11, cols_anuales])
valores_servicios_mex <- unlist(durables_servicios_mex_raw[14, cols_anuales])

durables_mex_anual <- tibble(
  anio = anios_anuales,
  durables_real = as.numeric(valores_durables_mex)
) |>
  filter(!is.na(anio), !is.na(durables_real)) |>
  arrange(anio)

servicios_mex_anual <- tibble(
  anio = anios_anuales,
  servicios_real = as.numeric(valores_servicios_mex)
) |>
  filter(!is.na(anio), !is.na(servicios_real)) |>
  arrange(anio)

tabla_durables_servicios_mex <- durables_mex_anual |>
  inner_join(servicios_mex_anual, by = "anio")
@

\begin{center}
Tabla. México: índice anual real de consumo de bienes durables y servicios
\end{center}
<<tabla_durables_servicios_mex, echo=FALSE, results='asis'>>=
durables_servicios_mex_tabla <- tabla_durables_servicios_mex |>
  transmute(
    anio = anio,
    durables_real = round(durables_real, 4),
    servicios_real = round(servicios_real, 4)
  )

mitad_dur_serv_mex <- ceiling(nrow(durables_servicios_mex_tabla) / 2)

izq_dur_serv_mex <- durables_servicios_mex_tabla |>
  slice(1:mitad_dur_serv_mex) |>
  rename(
    Año_1 = anio,
    Durables_1 = durables_real,
    Servicios_1 = servicios_real
    )
der_dur_serv_mex <- durables_servicios_mex_tabla |>
  slice((mitad_dur_serv_mex + 1):n())

if (nrow(der_dur_serv_mex) < nrow(izq_dur_serv_mex)) {
  der_dur_serv_mex <- bind_rows(
    der_dur_serv_mex,
    tibble(
      anio = NA_integer_,
      durables_real = NA_real_,
      servicios_real = NA_real_
    )
  )
}

durables_servicios_mex_tabla_6 <- bind_cols(
  izq_dur_serv_mex,
  der_dur_serv_mex |>
    rename(
      Año_2 = anio,
      Durables_2 = durables_real,
      Servicios_2 = servicios_real
    )
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    Durables_2 = ifelse(is.na(Durables_2), "", Durables_2),
    Servicios_2 = ifelse(is.na(Servicios_2), "", Servicios_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    durables_servicios_mex_tabla_6,
    format = "latex",
    booktabs = TRUE,
    col.names = c(
      "Año", "Durables", "Servicios",
      "Año", "Durables", "Servicios"
    ),
    digits = 4,
    align = "cccccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos del Instituto Nacional de Estadística y Geografía (INEGI).}\n")
cat("\\end{center}\n")
@

Para México se utilizan las series anuales del Índice de volumen físico base 2018=100 del Indicador Mensual del Consumo Privado, publicadas por INEGI. En particular, se seleccionan los componentes de consumo nacional en bienes durables y en servicios, tomando el valor anual reportado para cada año. Estas series representan el nivel real anual de ambos componentes del consumo de los hogares y constituyen la base para calcular posteriormente sus tasas de crecimiento anual.

<<durables_servicios_usa, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_durables_usa <- "DDURRA3M086SBEA monthly - FRED.xlsx"
ruta_servicios_usa <- "DSERRL1A225NBEA annual - FRED.xlsx"

# Bienes durables: serie mensual en índice real
durables_usa_raw <- read_excel(
  ruta_durables_usa,
  sheet = "Monthly"
)

durables_usa_anual <- durables_usa_raw |>
  mutate(
    observation_date = as.Date(observation_date),
    anio = lubridate::year(observation_date)
  ) |>
  group_by(anio) |>
  summarise(
    durables_real = mean(DDURRA3M086SBEA, na.rm = TRUE),
    .groups = "drop"
  ) |>
  filter(anio >= 1990) |>
  arrange(anio)

# Servicios: tasa de crecimiento anual real reportada por FRED
servicios_usa_raw <- read_excel(
  ruta_servicios_usa,
  sheet = "Annual"
)

servicios_usa_anual <- servicios_usa_raw |>
  mutate(
    observation_date = as.Date(observation_date),
    anio = lubridate::year(observation_date),
    crecimiento_servicios = as.numeric(DSERRL1A225NBEA)
  ) |>
  select(anio, crecimiento_servicios) |>
  filter(anio >= 1990) |>
  arrange(anio)

# Tabla conjunta para presentar datos
tabla_durables_servicios_usa <- durables_usa_anual |>
  inner_join(servicios_usa_anual, by = "anio")
@

\begin{center}
