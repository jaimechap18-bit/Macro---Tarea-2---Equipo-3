    durables_real = round(durables_real, 4),
    crecimiento_servicios = round(crecimiento_servicios, 4)
  )

mitad_dur_serv_usa <- ceiling(nrow(durables_servicios_usa_tabla) / 2)

izq_dur_serv_usa <- durables_servicios_usa_tabla |>
  slice(1:mitad_dur_serv_usa) |>
  rename(
    Año_1 = anio,
    Durables_1 = durables_real,
    Servicios_1 = crecimiento_servicios
  )

der_dur_serv_usa <- durables_servicios_usa_tabla |>
  slice((mitad_dur_serv_usa + 1):n())

if (nrow(der_dur_serv_usa) < nrow(izq_dur_serv_usa)) {
  der_dur_serv_usa <- bind_rows(
    der_dur_serv_usa,
    tibble(
      anio = NA_integer_,
      durables_real = NA_real_,
      crecimiento_servicios = NA_real_
    )
  )
}

durables_servicios_usa_tabla_6 <- bind_cols(
  izq_dur_serv_usa,
  der_dur_serv_usa |>
    rename(
      Año_2 = anio,
      Durables_2 = durables_real,
      Servicios_2 = crecimiento_servicios
    )
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    Durables_2 = ifelse(is.na(Durables_2), "", Durables_2),
    Servicios_2 = ifelse(is.na(Servicios_2), "", Servicios_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    durables_servicios_usa_tabla_6,
    format = "latex",
    booktabs = TRUE,
    col.names = c(
      "Año", "Durables", "Servicios (%)",
      "Año", "Durables", "Servicios (%)"
    ),
    digits = 4,
    align = "cccccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos de la Federal Reserve Economic Data (FRED), Federal Reserve Bank of St. Louis.}\n")
cat("\\end{center}\n")
@

Para Estados Unidos se emplean dos series publicadas por FRED con información de la BEA. En el caso de los bienes durables, se utiliza la serie mensual del índice real de consumo y se construye un promedio anual para cada año. Para los servicios, se emplea directamente la tasa de crecimiento anual real reportada por la fuente. La tabla presenta ambas series para el periodo de análisis y constituye la base para la construcción posterior de las covarianzas con el exceso de retorno accionario.

<<durables_servicios_esp, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_durables_servicios_esp <- "PIB real demanda - INE.xlsx"

durables_servicios_esp_raw <- read_excel(
  ruta_durables_servicios_esp,
  col_names = FALSE
)

# Fila de conceptos y columnas de trimestres
periodos_esp <- durables_servicios_esp_raw[8, -1] |> unlist() |> as.character()

# Filas relevantes según la estructura observada en la tabla de INE
fila_durables_esp <- durables_servicios_esp_raw[16, -1] |> unlist()
fila_servicios_esp <- durables_servicios_esp_raw[20, -1] |> unlist()

durables_esp_trimestral <- tibble(
  periodo = periodos_esp,
  durables_real = as.numeric(fila_durables_esp)
) |>
  filter(!is.na(periodo), str_detect(periodo, "^[0-9]{4}T[1-4]$")) |>
  mutate(
    anio = as.integer(str_sub(periodo, 1, 4))
  ) |>
  arrange(anio, periodo)

servicios_esp_trimestral <- tibble(
  periodo = periodos_esp,
  servicios_real = as.numeric(fila_servicios_esp)
) |>
  filter(!is.na(periodo), str_detect(periodo, "^[0-9]{4}T[1-4]$")) |>
  mutate(
    anio = as.integer(str_sub(periodo, 1, 4))
  ) |>
  arrange(anio, periodo)

durables_esp_anual <- durables_esp_trimestral |>
  group_by(anio) |>
  summarise(
    durables_real = mean(durables_real, na.rm = TRUE),
    .groups = "drop"
  ) |>
  filter(anio >= 1990, anio <= 2025)

servicios_esp_anual <- servicios_esp_trimestral |>
  group_by(anio) |>
  summarise(
    servicios_real = mean(servicios_real, na.rm = TRUE),
    .groups = "drop"
  ) |>
  filter(anio >= 1990, anio <= 2025)

tabla_durables_servicios_esp <- durables_esp_anual |>
  inner_join(servicios_esp_anual, by = "anio")
@

\begin{center}
Tabla. España: índice anual real de consumo de bienes durables y servicios
\end{center}
<<tabla_durables_servicios_esp, echo=FALSE, results='asis'>>=
durables_servicios_esp_tabla <- tabla_durables_servicios_esp |>
  transmute(
    anio = anio,
    durables_real = round(durables_real, 4),
    servicios_real = round(servicios_real, 4)
  )

mitad_dur_serv_esp <- ceiling(nrow(durables_servicios_esp_tabla) / 2)

izq_dur_serv_esp <- durables_servicios_esp_tabla |>
  slice(1:mitad_dur_serv_esp) |>
  rename(
    Año_1 = anio,
    Durables_1 = durables_real,
    Servicios_1 = servicios_real
  )

der_dur_serv_esp <- durables_servicios_esp_tabla |>
  slice((mitad_dur_serv_esp + 1):n())

if (nrow(der_dur_serv_esp) < nrow(izq_dur_serv_esp)) {
  der_dur_serv_esp <- bind_rows(
    der_dur_serv_esp,
    tibble(
      anio = NA_integer_,
      durables_real = NA_real_,
      servicios_real = NA_real_
    )
  )
}

durables_servicios_esp_tabla_6 <- bind_cols(
  izq_dur_serv_esp,
  der_dur_serv_esp |>
    rename(
      Año_2 = anio,
      Durables_2 = durables_real,
      Servicios_2 = servicios_real
    )
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    Durables_2 = ifelse(is.na(Durables_2), "", Durables_2),
    Servicios_2 = ifelse(is.na(Servicios_2), "", Servicios_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    durables_servicios_esp_tabla_6,
    format = "latex",
    booktabs = TRUE,
    col.names = c(
      "Año", "Durables", "Servicios",
      "Año", "Durables", "Servicios"
    ),
    digits = 4,
    align = "cccccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos del Instituto Nacional de Estadística (INE) de España.}\n")
cat("\\end{center}\n")
@

Para España se utilizan las series trimestrales de gasto en consumo final interior de los hogares en bienes durables y en servicios, expresadas en términos reales dentro de la base de demanda del INE. Dado que la fuente original se encuentra en frecuencia trimestral, para este inciso se construyó una serie anual mediante el promedio de los cuatro trimestres de cada año. La tabla presenta los niveles anuales de ambos componentes y constituye la base para calcular posteriormente sus tasas de crecimiento anual.

<<crecimiento_durables_servicios_mex, echo=FALSE, message=FALSE, warning=FALSE>>=
crecimiento_durables_mex <- durables_mex_anual |>
  arrange(anio) |>
  mutate(
    crecimiento_durables = ((durables_real / lag(durables_real)) - 1) * 100
  ) |>
  select(anio, crecimiento_durables)

crecimiento_servicios_mex <- servicios_mex_anual |>
  arrange(anio) |>
  mutate(
    crecimiento_servicios = ((servicios_real / lag(servicios_real)) - 1) * 100
  ) |>
  select(anio, crecimiento_servicios)

tabla_crecimiento_durables_servicios_mex <- crecimiento_durables_mex |>
  inner_join(crecimiento_servicios_mex, by = "anio") |>
  filter(!is.na(crecimiento_durables), !is.na(crecimiento_servicios))
@

