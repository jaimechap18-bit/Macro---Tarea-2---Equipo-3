cat("\\end{center}\n")
@

Para Estados Unidos, la tasa de retorno nominal anual se calculó usando el cierre anual del NASDAQ Composite. La serie permite observar los años de expansión y contracción del mercado accionario estadounidense dentro del periodo analizado.

\begin{center}
Tabla. España: tasa de retorno nominal anual del IBEX 35
\end{center}
<<tabla_retornos_ibex, echo=FALSE, results='asis'>>=
tabla_retornos_ibex <- retornos_ibex |>
  mutate(retorno_ibex = round(retorno_ibex, 4)) |>
  filter(!is.na(retorno_ibex))

mitad_ret_ibex <- ceiling(nrow(tabla_retornos_ibex) / 2)

izq_ret_ibex <- tabla_retornos_ibex |>
  slice(1:mitad_ret_ibex) |>
  rename(Año_1 = anio, Retorno_1 = retorno_ibex)

der_ret_ibex <- tabla_retornos_ibex |>
  slice((mitad_ret_ibex + 1):n())

if (nrow(der_ret_ibex) < nrow(izq_ret_ibex)) {
  der_ret_ibex <- bind_rows(
    der_ret_ibex,
    tibble(anio = NA_integer_, retorno_ibex = NA_real_)
  )
}

tabla_retornos_ibex_4 <- bind_cols(
  izq_ret_ibex,
  der_ret_ibex |> rename(Año_2 = anio, Retorno_2 = retorno_ibex)
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    Retorno_2 = ifelse(is.na(Retorno_2), "", Retorno_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    tabla_retornos_ibex_4,
    format = "latex",
    booktabs = TRUE,
    col.names = c("Año", "Retorno \\%", "Año", "Retorno \\%"),
    digits = 4,
    align = "cccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos de Yahoo Finance.}\n")
cat("\\end{center}\n")
@

Para España, la tasa de retorno nominal anual se calculó a partir del cierre anual del IBEX 35. Al igual que en los otros casos, el cálculo refleja la variación porcentual anual del índice respecto al año previo.

\newpage
\textbf{(c) Tasa de interés anual promedio a un año para los tres países}

<<cetes_mexico, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_cetes_mex <- "Cetes a 364 días daily - Banxico.xlsx"

cetes_mex_raw <- read_excel(ruta_cetes_mex, sheet = "Hoja1", skip = 17)

cetes_mex_diario <- cetes_mex_raw |>
  rename(
    fecha = 1,
    cetes_364 = 2
  ) |>
  mutate(
    fecha = as.Date(fecha),
    cetes_364 = as.numeric(cetes_364)
  ) |>
  filter(!is.na(fecha), !is.na(cetes_364)) |>
  mutate(
    anio = year(fecha)
  ) |>
  arrange(fecha)

cetes_mex_anual <- cetes_mex_diario |>
  group_by(anio) |>
  summarise(
    cetes_364_promedio_anual = mean(cetes_364, na.rm = TRUE),
    .groups = "drop"
  )
@

