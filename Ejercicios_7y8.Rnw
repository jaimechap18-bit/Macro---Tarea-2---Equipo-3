\newpage
\textbf{(e) Covarianza entre el exceso de retorno y el crecimiento real del consumo agregado}

<<consumo_mexico, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_consumo_mex <- "CP_indice monthly - INEGI.xlsx"

consumo_mex_raw <- read_excel(
  ruta_consumo_mex,
  sheet = "Tabulado",
  col_names = FALSE
)

anios_mex <- consumo_mex_raw[5, -1] |> unlist() |> as.character()
periodos_mex <- consumo_mex_raw[6, -1] |> unlist() |> as.character()
fila_total_mex <- consumo_mex_raw[8, -1] |> unlist()

consumo_mex_anual <- tibble(
  anio = anios_mex,
  periodo = periodos_mex,
  consumo_real = fila_total_mex
) |>
  mutate(
    anio = na_if(anio, "NA")
  ) |>
  fill(anio) |>
  filter(periodo == "Anual") |>
  mutate(
    anio = as.integer(anio),
    consumo_real = as.numeric(consumo_real)
  ) |>
  filter(!is.na(anio), !is.na(consumo_real)) |>
  arrange(anio)
@

