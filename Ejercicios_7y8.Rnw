Para Estados Unidos se utiliza la serie \textit{Consumer Price Index for All Urban Consumers: All Items in U.S. City Average} (CPIAUCSL), obtenida de FRED. Dado que la serie original se encuentra en frecuencia mensual, se construyó una serie anual usando el promedio de los doce meses de cada año. En la tabla se reportan únicamente años completos.

<<ipc_espana, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_ipc_esp <- "INPC España monthly - INE.xlsx"

ipc_esp_raw <- read_excel(
  ruta_ipc_esp,
  sheet = "tabla-76125",
  col_names = FALSE
)

encabezados <- ipc_esp_raw[8, ] |> unlist() |> as.character()

fila_indice_general <- ipc_esp_raw[9, ] |> unlist()

ipc_esp_mensual <- tibble(
  periodo = encabezados[-1],
  ipc = as.numeric(fila_indice_general[-1])
) |>
  filter(!is.na(periodo), !is.na(ipc)) |>
  mutate(
    anio = as.integer(str_sub(periodo, 1, 4)),
    mes  = as.integer(str_sub(periodo, 6, 7)),
    fecha = as.Date(sprintf("%d-%02d-01", anio, mes))
  ) |>
  select(fecha, anio, mes, ipc) |>
  arrange(fecha)

ipc_esp_anual <- ipc_esp_mensual |>
  group_by(anio) |>
  summarise(
    ipc_promedio_anual = mean(ipc, na.rm = TRUE),
    .groups = "drop"
  ) |>
  filter(anio >= 1990, anio <= 2025
         )
@

