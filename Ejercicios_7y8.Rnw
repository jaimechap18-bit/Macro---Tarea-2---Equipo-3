Para México se utiliza la serie del índice de consumo privado, obtenida de INEGI. Dado que la información original se encuentra en frecuencia mensual, se construyó una serie anual a partir del promedio de las observaciones disponibles dentro de cada año. Esta base aproxima la evolución real del consumo agregado de los hogares.

<<consumo_usa, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_consumo_usa <- "PCECCA annual - FRED.xlsx"

consumo_usa_raw <- read_excel(ruta_consumo_usa, sheet = "Annual")

consumo_usa_anual <- consumo_usa_raw |>
  rename(
    fecha = observation_date,
    consumo_real = PCECCA
  ) |>
  mutate(
    fecha = as.Date(fecha),
    anio = year(fecha),
    consumo_real = as.numeric(consumo_real)
  ) |>
  select(anio, consumo_real) |>
  filter(!is.na(anio), !is.na(consumo_real)) |>
  arrange(anio)
@

\begin{center}
Tabla. Estados Unidos: consumo personal real, nivel anual
\end{center}
<<tabla_consumo_usa, echo=FALSE, results='asis'>>=
consumo_usa_tabla <- consumo_usa_anual |>
  transmute(
    anio = anio,
    consumo_real = format(
      round(consumo_real, 4),
      big.mark = ",",
      scientific = FALSE,
      nsmall = 4,
      trim = TRUE
    )
  )

mitad_consumo_usa <- ceiling(nrow(consumo_usa_tabla) / 2)

izq_consumo_usa <- consumo_usa_tabla |>
  slice(1:mitad_consumo_usa) |>
  rename(Año_1 = anio, Consumo_1 = consumo_real)

der_consumo_usa <- consumo_usa_tabla |>
  slice((mitad_consumo_usa + 1):n())

if (nrow(der_consumo_usa) < nrow(izq_consumo_usa)) {
  der_consumo_usa <- bind_rows(
    der_consumo_usa,
    tibble(anio = NA_integer_, consumo_real = NA_character_)
  )
}

consumo_usa_tabla_4 <- bind_cols(
  izq_consumo_usa,
  der_consumo_usa |> rename(Año_2 = anio, Consumo_2 = consumo_real)
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    Consumo_2 = ifelse(is.na(Consumo_2), "", Consumo_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    consumo_usa_tabla_4,
    format = "latex",
    booktabs = TRUE,
    col.names = c("Año", "Consumo", "Año", "Consumo"),
    align = "cccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos de la Federal Reserve Economic Data (FRED), Federal Reserve Bank of St. Louis.}\n")
cat("\\end{center}\n")
@

Para Estados Unidos se utiliza la serie \textit{Real Personal Consumption Expenditures}, obtenida de FRED. Esta base representa el nivel anual del consumo agregado real y servirá posteriormente para calcular su tasa de crecimiento anual.

<<consumo_espana, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_consumo_esp <- "Consumo privado - Banco de España.xlsx"

consumo_esp_raw <- read_excel(
  ruta_consumo_esp,
  sheet = "BDMACRO_A",
  col_names = FALSE
)

anios_esp <- consumo_esp_raw[3, 13:ncol(consumo_esp_raw)] |>
  unlist() |>
  as.numeric()

fila_consumo_esp <- consumo_esp_raw[16, 13:ncol(consumo_esp_raw)] |>
  unlist() |>
  as.numeric()

consumo_esp_anual <- tibble(
  anio = anios_esp,
  consumo_real = fila_consumo_esp
) |>
  mutate(
    anio = as.integer(anio)
  ) |>
  filter(!is.na(anio), !is.na(consumo_real)) |>
  arrange(anio)
@

