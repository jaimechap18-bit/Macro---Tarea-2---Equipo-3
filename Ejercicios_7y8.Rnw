Para España se utiliza la serie del índice general de precios al consumidor obtenida del Instituto Nacional de Estadística (INE). Dado que la información original se encuentra en frecuencia mensual, se construyó una serie anual usando el promedio de los doce meses de cada año. En la tabla se reportan únicamente años completos.

<<ipc_bmv_mexico, echo=FALSE, message=FALSE, warning=FALSE>>=
ruta_ipc_bmv <- "IPC BMV daily - Banxico.xlsx"

ipc_bmv_raw <- read_excel(ruta_ipc_bmv, sheet = "Hoja1", skip = 17)

ipc_bmv_diario <- ipc_bmv_raw |>
  rename(
    fecha = 1,
    ipc_bmv = 5
  ) |>
  filter(!is.na(fecha), !is.na(ipc_bmv)) |>
  mutate(
    fecha = as.POSIXct(fecha, tz = "UTC"),
    fecha = as.Date(fecha),
    anio = year(fecha)
  ) |>
  select(fecha, ipc_bmv, anio) |>
  arrange(fecha)

ipc_bmv_anual <- ipc_bmv_diario |>
  group_by(anio) |>
  slice_tail(n = 1) |>
  ungroup() |>
  transmute(
    anio,
    fecha_cierre = fecha,
    ipc_bmv_cierre_anual = ipc_bmv
  ) |>
  filter(anio >= 1990, anio <= 2025
         )
@

\begin{center}
Tabla. México: Índice de Precios y Cotizaciones de la Bolsa Mexicana de Valores, cierre anual
\end{center}
<<tabla_ipc_bmv_mexico, echo=FALSE, results='asis'>>=
ipc_bmv_tabla <- ipc_bmv_anual |>
  transmute(
    anio = anio,
    ipc_bmv = format(
      round(ipc_bmv_cierre_anual, 4),
      big.mark = ",",
      scientific = FALSE,
      nsmall = 4,
      trim = TRUE
    )
  )

mitad_ipc_bmv <- ceiling(nrow(ipc_bmv_tabla) / 2)

izq_ipc_bmv <- ipc_bmv_tabla |>
  slice(1:mitad_ipc_bmv) |>
  rename(Año_1 = anio, IPC_BMV_1 = ipc_bmv)

der_ipc_bmv <- ipc_bmv_tabla |>
  slice((mitad_ipc_bmv + 1):n())

if (nrow(der_ipc_bmv) < nrow(izq_ipc_bmv)) {
  der_ipc_bmv <- bind_rows(
    der_ipc_bmv,
    tibble(anio = NA_integer_, ipc_bmv = NA_character_)
  )
}

ipc_bmv_tabla_4 <- bind_cols(
  izq_ipc_bmv,
  der_ipc_bmv |> rename(Año_2 = anio, IPC_BMV_2 = ipc_bmv)
) |>
  mutate(
    Año_2 = ifelse(is.na(Año_2), "", Año_2),
    IPC_BMV_2 = ifelse(is.na(IPC_BMV_2), "", IPC_BMV_2)
  )

cat("\\begin{center}\n")
print(
  kable(
    ipc_bmv_tabla_4,
    format = "latex",
    booktabs = TRUE,
    col.names = c("Año", "IPC BMV", "Año", "IPC BMV"),
    align = "cccc"
  )
)
cat("\\\\[0.3em]\n")
cat("{\\footnotesize Fuente: Elaboración propia con base en datos del Banco de México (Banxico).}\n")
cat("\\end{center}\n")
@

Para México se utiliza el Índice de Precios y Cotizaciones de la Bolsa Mexicana de Valores, obtenido de Banco de México. Dado que la serie original se encuentra en frecuencia diaria, se construyó una serie anual utilizando el último valor disponible de cada año, es decir, el cierre anual del índice. En la tabla se reportan únicamente años completos.

